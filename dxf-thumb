#!/usr/bin/env python3
"""
DXF → PNG thumbnail (Freedesktop .thumbnailer friendly)

Melhorias em relação à versão original:
- Tenta layouts/paperspace se modelspace não tiver conteúdo visível
- Gera placeholder branco em vez de falhar com exit != 0 em desenho vazio
- Erros impressos no stderr para diagnóstico
- PNG salvo com optimize=True para menor tamanho em disco

Exit codes:
    0  sucesso (incluindo placeholder para desenho vazio)
    1  argumentos errados
    2  arquivo não encontrado
    3  falha ao renderizar (DXF inválido / dependências ausentes)

Uso:
  dxf-thumb INPUT size OUTPUT
Ex:
  python3 dxf-thumb /caminho/arquivo.dxf 256 /tmp/out.png
"""

import os
import sys
import tempfile
from pathlib import Path
from urllib.parse import urlparse, unquote

import matplotlib
matplotlib.use("Agg")
from matplotlib.figure import Figure
from matplotlib.backends.backend_agg import FigureCanvasAgg

import ezdxf
from ezdxf.addons.drawing import RenderContext, Frontend
from ezdxf.addons.drawing.matplotlib import MatplotlibBackend
from ezdxf.addons.drawing import config as draw_config

from PIL import Image, ImageChops


# Ajustes visuais (comece por aqui se quiser afinar)
LINEWEIGHT_SCALING = 1.8   # 1.3 a 2.5
MIN_LINEWEIGHT     = 3.0   # 2.0 a 6.0 (impacta legibilidade no thumbnail)
MARGIN_RATIO       = 0.06  # margem interna no thumbnail final (6%)
VIEW_PAD_RATIO     = 0.05  # margem no "view" em unidades do DXF (5%)
MAX_THUMB          = 1024
MIN_THUMB          = 32


def _to_path(s: str) -> Path:
    if s.startswith("file://"):
        s = unquote(urlparse(s).path)
    return Path(s).expanduser()


def _crop_to_content(im_rgb: Image.Image) -> Image.Image:
    bg   = Image.new("RGB", im_rgb.size, "white")
    diff = ImageChops.difference(im_rgb, bg)
    bbox = diff.getbbox()
    if not bbox:
        return im_rgb
    return im_rgb.crop(bbox)


def _render_layout(doc, layout, ax) -> bool:
    """
    Renderiza um layout no eixo fornecido.
    Retorna True se houve conteúdo visível (dataLim não trivial).
    """
    ctx = RenderContext(doc)
    cfg = draw_config.Configuration(
        background_policy=draw_config.BackgroundPolicy.WHITE,
        color_policy=draw_config.ColorPolicy.BLACK,
        lineweight_scaling=LINEWEIGHT_SCALING,
        min_lineweight=MIN_LINEWEIGHT,
    )
    backend = MatplotlibBackend(ax, adjust_figure=False)
    Frontend(ctx, backend, config=cfg).draw_layout(layout, finalize=True)

    dl = ax.dataLim
    if dl.width > 0 and dl.height > 0:
        xmin, ymin, xmax, ymax = dl.x0, dl.y0, dl.x1, dl.y1
        w   = xmax - xmin
        h   = ymax - ymin
        pad = max(w, h) * VIEW_PAD_RATIO
        ax.set_xlim(xmin - pad, xmax + pad)
        ax.set_ylim(ymin - pad, ymax + pad)
        ax.set_aspect("equal", adjustable="box")
        return True

    return False


def _pick_layout(doc):
    """
    Retorna o melhor layout para thumbnail:
    1. Model space se tiver entidades
    2. Maior paperspace layout (pelo número de entidades)
    3. Model space como fallback
    """
    msp = doc.modelspace()
    if len(msp) > 0:
        return msp

    best       = None
    best_count = -1
    for layout in doc.layouts:
        if layout.is_modelspace:
            continue
        count = len(layout)
        if count > best_count:
            best_count = count
            best       = layout

    return best if best is not None else msp


def main() -> int:
    if len(sys.argv) != 4:
        print("Uso: dxf-thumb INPUT size OUTPUT", file=sys.stderr)
        return 1

    inp = _to_path(sys.argv[1])
    try:
        size = int(sys.argv[2])
    except ValueError:
        return 1
    out = Path(sys.argv[3])

    if not inp.exists():
        print(f"Arquivo não encontrado: {inp}", file=sys.stderr)
        return 2

    size      = max(MIN_THUMB, min(size, MAX_THUMB))
    render_px = max(768, size * 4)
    dpi       = 100

    fig = Figure(figsize=(render_px / dpi, render_px / dpi), dpi=dpi)
    FigureCanvasAgg(fig)
    ax = fig.add_axes((0, 0, 1, 1))
    ax.set_axis_off()
    fig.patch.set_facecolor("white")
    ax.set_facecolor("white")

    tmp_path = None
    try:
        doc    = ezdxf.readfile(inp)
        layout = _pick_layout(doc)

        has_content = _render_layout(doc, layout, ax)

        if not has_content:
            # Desenho sem conteúdo visível: salva placeholder branco
            Image.new("RGB", (size, size), "white").save(out, "PNG", optimize=True)
            return 0

        with tempfile.NamedTemporaryFile(suffix=".png", delete=False) as tmp:
            tmp_path = tmp.name

        fig.savefig(tmp_path, dpi=dpi, facecolor="white", edgecolor="none")

        im = Image.open(tmp_path).convert("RGB")
        im = _crop_to_content(im)

        margin    = max(2, int(size * MARGIN_RATIO))
        max_inner = max(1, size - 2 * margin)

        w, h = im.size
        if w <= 0 or h <= 0:
            Image.new("RGB", (size, size), "white").save(out, "PNG", optimize=True)
            return 0

        scale  = max_inner / max(w, h)
        new_w  = max(1, int(w * scale))
        new_h  = max(1, int(h * scale))

        im     = im.resize((new_w, new_h), Image.Resampling.LANCZOS)
        canvas = Image.new("RGB", (size, size), "white")
        x      = (size - new_w) // 2
        y      = (size - new_h) // 2
        canvas.paste(im, (x, y))
        canvas.save(out, "PNG", optimize=True)

        return 0

    except Exception as e:
        print(f"Erro ao renderizar {inp.name}: {e}", file=sys.stderr)
        return 3

    finally:
        if tmp_path:
            try:
                os.unlink(tmp_path)
            except OSError:
                pass


if __name__ == "__main__":
    raise SystemExit(main())
